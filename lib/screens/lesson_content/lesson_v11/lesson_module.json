        "icon": "⚡",
        "content": [
          {
            "id": "blk_003",
            "order": 1,
            "type": "markdown",
            "content": {
              "body": "## Taneciklerin Hareketi\nTanecikler sürekli hareket eder.\n\n- Katılarda: yavaş hareket\n- Sıvılarda: orta hız\n- Gazlarda: hızlı hareket\n\nBu hareket, maddenin halini belirler."
            }
          },
          {
            "id": "blk_004",
            "order": 2,
            "type": "misconception",
            "content": {
              "wrong": "Tanecikler sadece ısıtıldığında hareket eder.",
              "correct": "Tanecikler her zaman hareket halindedir.",
              "tip": "Soğukta bile hareket devam eder."
            }
          }
        ],
        "quiz": [
          {
